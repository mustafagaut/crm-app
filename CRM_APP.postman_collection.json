{
  "info": {
    "name": "CRM App API",
    "description": "Endpoints for the MERN CRM app (mustafagaut/crm-app), built from the README's API Overview. Set `baseUrl` to http://localhost:5000 for local dev, or https://crm-app-kbnu.onrender.com for the live deployment.\n\nFlow: run 'Signup (User)' or 'Login (User)' first — the test script on Login automatically saves the returned access token into `accessToken` so every other request can reuse it via the Authorization header.\n\nNote: token field names in the login/signup responses (e.g. `accessToken` vs `token`) are guessed from the README's description of a consistent `{ success, message, data }` response shape. If your actual response uses different field names, adjust the test script in the Login request accordingly — I don't have visibility into the controller code to confirm the exact shape.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "adminAccessToken", "value": "", "type": "string" },
    { "key": "adminSecretKey", "value": "", "type": "string" },
    { "key": "contactId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Reports success', function () {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Signup (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Admin\",\n  \"email\": \"testadmin@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"Admin\",\n  \"adminSecretKey\": \"{{adminSecretKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Requires `adminSecretKey` to match the backend's ADMIN_SECRET_KEY env var. Set the `adminSecretKey` collection variable before running this."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 (or 403 if adminSecretKey is wrong/missing)', function () {",
                  "    pm.expect([201, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Save whatever token fields come back so later requests can reuse them.",
                  "// Adjust the key names below if your response shape differs.",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "const data = body.data || body;",
                  "",
                  "const access = data.accessToken || data.token;",
                  "const refresh = data.refreshToken;",
                  "",
                  "if (access) pm.collectionVariables.set('accessToken', access);",
                  "if (refresh) pm.collectionVariables.set('refreshToken', refresh);",
                  "",
                  "pm.test('Access token was captured', function () {",
                  "    pm.expect(access, 'expected an access/refresh token in the response body — check field names in the test script if this fails').to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Demo Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Uses the demo admin account listed in the README for review purposes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "const data = body.data || body;",
                  "const access = data.accessToken || data.token;",
                  "if (access) pm.collectionVariables.set('adminAccessToken', access);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "profile"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "List Contacts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/contacts?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contacts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Contact",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"5551234567\",\n  \"company\": \"Initech\",\n  \"status\": \"Lead\",\n  \"notes\": \"Created via Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contacts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "const data = body.data || body;",
                  "if (data && data._id) {",
                  "    pm.collectionVariables.set('contactId', data._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Contact",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"5551234567\",\n  \"company\": \"Initech\",\n  \"status\": \"Customer\",\n  \"notes\": \"Updated via Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/contacts/{{contactId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contacts", "{{contactId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Contact",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/contacts/{{contactId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contacts", "{{contactId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Activity Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "logs"]
            },
            "description": "Run 'Login (Demo Admin)' first to populate {{adminAccessToken}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Non-admin cannot reach this without failing (sanity check skipped — see Dashboard Stats request for a 403 example)', function () {});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminAccessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard-stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "dashboard-stats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Activity Logs (as non-admin — expect 403)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "logs"]
            },
            "description": "Uses the regular user's {{accessToken}} instead of {{adminAccessToken}} to confirm RBAC actually blocks non-admins."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 403 (RBAC correctly blocks non-admin)', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
